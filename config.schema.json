{
  "pluginAlias": "TapoDL100",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "locks": {
        "type": "array", "title": "Locks",
        "items": { "type": "object", "properties": {
          "name": { "title": "Name (match Tapo app name exactly)", "type": "string", "default": "Front Door" },
          "ip": { "title": "Lock IP address", "type": "string", "required": true },
          "cloudUsername": { "title": "TP-Link / Tapo email", "type": "string", "required": true },
          "cloudPassword": { "title": "TP-Link / Tapo password", "type": "string", "required": true },
          "pollSeconds": { "title": "Poll interval (s)", "type": "integer", "default": 300 }
        } }
      }
    }
  }
}
